{
  "name": "park_chain_backend",
  "version": "1.0.0",
  "type": "commonjs",
  "description": "Parking spot booking backend with XRPL payments",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon --dns-result-order=ipv4first index.js",
    "migrate": "node src/config/migrate.js",
    "seed:admin": "node src/scripts/seedAdmin.js",
    "generate-admin-wallet": "node src/scripts/generateAdminWallet.js",
    "generate:wallet": "node src/scripts/generateAdminWallet.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.0",
    "express-rate-limit": "^8.4.1",
    "firebase-admin": "^13.8.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^4.5.0",
    "node-fetch": "^2.7.0",
    "pg": "^8.20.0",
    "uuid": "^10.0.0",
    "ws": "^8.20.0",
    "xrpl": "^3.1.0",
    "xumm-sdk": "^1.11.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "jest-mock": "^30.3.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/controllers/**/*.js",
      "src/models/**/*.js",
      "src/services/**/*.js"
    ],
    "coverageDirectory": "coverage"
  }
}
